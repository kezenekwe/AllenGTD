# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info           # error | warn | info | http | debug

# ─── Database ─────────────────────────────────────────────────────────────────
# Use a connection URL (preferred on managed platforms):
# DATABASE_URL=postgresql://user:password@host:5432/allen_gtd
#
# Or set individual vars:
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=allen_gtd
DB_USER=allen_user
DB_PASSWORD=your-secure-db-password
DB_SSL=true              # Set to true on Render / Railway / Supabase

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# Leave empty to allow all origins (fine for mobile-only APIs).
CORS_ORIGIN=https://yourapp.com,https://www.yourapp.com

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Requests per IP per 15-minute window.
RATE_LIMIT_GENERAL=1000  # General API
RATE_LIMIT_AUTH=20       # Login / register (brute-force protection)
